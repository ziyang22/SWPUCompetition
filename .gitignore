# .gitignore for Projection Method C++ Project

# Compiled Object files
*.o
*.obj
*.ko
*.elf

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
projection_method
projection_method.exe

# Build directories
build/
cmake-build-*/
.cmake/

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
Makefile.cmake

# IDE specific files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Output files (generated by the program)
output/*.txt
!output/.gitkeep

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/

# Jupyter Notebook
.ipynb_checkpoints

# Distribution / packaging
.Python
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Keep example outputs in data directory
!data/*/pass_last_5m_*.txt
!data/*/stuck_point_*.txt
!data/*/final_result_*.txt
